{
    "version": 8,
    "configurePresets":
    [
        {
            "name": "static",
            "cacheVariables":
            {
                "BUILD_SHARED_LIBS": "OFF",
                "ENABLE_TESTING": "OFF",
                "DMALLOC_DEBUG": "OFF"
            }
        },
        {
            "name": "shared",
            "cacheVariables":
            {
                "BUILD_SHARED_LIBS": "ON",
                "ENABLE_TESTING": "OFF",
                "DMALLOC_DEBUG": "OFF"
            }
        },
        {
            "name": "test",
            "inherits":
            [
                "shared"
            ],
            "cacheVariables":
            {
                "ENABLE_TESTING": "ON",
                "DMALLOC_DEBUG": "OFF"
            }     
        },
        {
            "name": "debug",
            "inherits":
            [
                "shared"
            ],
            "cacheVariables":
            {
                "DMALLOC_DEBUG": "ON"
            }     
        }
    ]
}